64r6#!/bin/bash
# /usr/bin/tos-session - Canonical Wayland OS entry point

# 1. Environment Configuration
export XDG_CURRENT_DESKTOP=TOS
export XDG_SESSION_DESKTOP=TOS
export XDG_SESSION_TYPE=wayland

# 2. Logging Setup
mkdir -p "$HOME/.local/share/tos/logs"
LOG_FILE="$HOME/.local/share/tos/logs/session.log"
exec > >(tee -a "$LOG_FILE") 2>&1

echo "[TOS-SESSION] Starting session at $(date)"

# 3. Brain Core & Display Face Orchestration
# The --orchestrate flag tells the brain to spawn auxiliary daemons.
# We run the brain in the background so the script can proceed to the face.
echo "[TOS-SESSION] Launching Brain with Orchestration..."
/usr/bin/tos-brain --headless --orchestrate &

# Wait for brain and services to stabilize
sleep 2

# 4. Launch the primary Wayland face inside a minimal compositor
# We prefer Sway or Cage for a minimal dedicated TOS session.
echo "[TOS-SESSION] Searching for a suitable Wayland compositor..."

if command -v sway >/dev/null 2>&1; then
    echo "[TOS-SESSION] Found Sway. Launching..."
    exec sway --config /etc/tos/sway.config
elif command -v cage >/dev/null 2>&1; then
    echo "[TOS-SESSION] Found Cage. Launching face directly..."
    exec cage -- /usr/bin/tos-wayland-face
elif [ -f /usr/bin/gnome-shell ]; then
    echo "[TOS-SESSION] Falling back to GNOME Shell (Wayland mode)..."
    # Note: This is a heavy fallback and might not use the minimal config.
    exec gnome-shell --wayland -- /usr/bin/tos-wayland-face
else
    echo "[TOS-SESSION] ERROR: No suitable Wayland compositor found (tried sway, cage, gnome-shell)."
    echo "[TOS-SESSION] Please install sway or cage: sudo apt install sway cage"
    sleep 10
    exit 1
fi
