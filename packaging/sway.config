# TOS Minimal Sway Configuration
# This config is used when launching TOS from GDM.

# 1. Input/Output
# Standard defaults, can be overridden by user in ~/.config/sway/config
input * {
    xkb_layout "us"
}

# 2. Appearance
# Disable window decorations and bars for the TOS "Face"
default_border none
default_floating_border none
hide_edge_borders both

# 3. Autostart TOS Face
# We use 'exec' to start the face as the primary occupant of the compositor.
# The brain and daemons are already started by the tos-session script.
exec /usr/bin/tos-wayland-face

# 4. Keybindings (Emergency only)
# Allow user to exit the session if something goes wrong
bindsym Mod4+Shift+e exec swaynag -t warning -m 'Exit TOS?' -b 'Yes' 'swaymsg exit'
