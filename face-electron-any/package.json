{
    "name": "face-electron-any",
    "version": "2.2.1",
    "description": "TOS Desktop Environment — Electron Face Container",
    "author": "TOS Project",
    "homepage": "https://github.com/KellyDev-Tools/TOS-Desktop-Environment",
    "private": true,
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "npm run build && electron dist/main.js",
        "dev": "tsc -p tsconfig.json && electron dist/main.js --dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "pack:win": "npm run build && electron-builder --win",
        "pack:mac": "npm run build && electron-builder --mac",
        "pack:linux": "npm run build && electron-builder --linux",
        "pack:all": "npm run build && electron-builder --win --mac --linux"
    },
    "dependencies": {
        "electron-store": "^8.1.0",
        "electron-updater": "^6.1.7"
    },
    "devDependencies": {
        "@types/node": "^20.11.5",
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3",
        "typescript": "^5.9.3",
        "vitest": "^4.1.1"
    },
    "build": {
        "extends": "./electron-builder.json"
    }
}
