pkgname=tos
pkgver=0.1.0_beta.0
pkgrel=1
pkgdesc="Tactical Operating System"
arch=('x86_64')
url="https://tos-project.org"
license=('GPL3')
depends=('wayland' 'libxkbcommon')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    make build-services
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -Dm755 target/release/tos-brain "$pkgdir/usr/bin/tos-brain"
    install -Dm755 target/release/tos "$pkgdir/usr/bin/tos"
    install -Dm644 packaging/tos.desktop "$pkgdir/usr/share/xsessions/tos.desktop"
}
